import { Button, LineEdit, ListView, StandardButton, HorizontalBox, VerticalBox } from "std-widgets.slint";

struct LinkItem {
    id: int,
    name: string,
    url: string,
}

export component MainWindow inherits Window {
    in-out property <bool> is_manage_page: false;
    in-out property <[LinkItem]> links: [];
    in-out property <string> edit_name: "";
    in-out property <string> edit_url: "";
    in-out property <int> edit_id: 0;
    in-out property <bool> show_add_dialog: false;
    in-out property <bool> show_edit_dialog: false;
    in-out property <bool> show_delete_dialog: false;
    in-out property <string> message_text: "";
    in-out property <string> message_type: "success";

    preferred-width: 900px;
    preferred-height: 700px;
    title: "电视直播导航";

    callback add_link();
    callback update_link(int, string, string);
    callback delete_link(int);
    callback show_message(string, string);
    callback open_link(string);

    public function navigate-to-manage() {
        self.is_manage_page = true;
    }

    public function navigate-to-home() {
        self.is_manage_page = false;
    }

    Rectangle {
        width: parent.width;
        height: parent.height;

        VerticalBox {
            padding: 20px;
            spacing: 15px;

            HorizontalBox {
                Text {
                    text: "电视直播导航";
                    font-size: 24px;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    horizontal-stretch: 1;
                }

                if (!root.is_manage_page) : Button {
                    text: "管理节目";
                    clicked => {
                        root.navigate-to-manage();
                    }
                }

                if (root.is_manage_page) : Button {
                    text: "返回首页";
                    clicked => {
                        root.navigate-to-home();
                    }
                }
            }

            if (!root.is_manage_page) : VerticalBox {
                Text {
                    text: "轻松跳转到您喜爱的电视台直播";
                    font-size: 14px;
                }

                ListView {
                    for link in root.links: HorizontalLayout {
                        spacing: 10px;

                        Text {
                            text: link.id;
                            vertical-alignment: center;
                        }

                        Text {
                            text: link.name;
                            vertical-alignment: center;
                        }

                        Text {
                            text: link.url;
                            color: blue;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.open_link(link.url);
                            }
                        }
                    }
                }
            }

            if (root.is_manage_page) : VerticalBox {
                HorizontalBox {
                    Text {
                        text: "节目列表";
                        font-size: 18px;
                        vertical-alignment: center;
                    }

                    HorizontalLayout {
                        horizontal-stretch: 1;
                    }

                    Button {
                        text: "添加节目";
                        clicked => {
                            root.edit_name = "";
                            root.edit_url = "";
                            root.edit_id = 0;
                            root.show_add_dialog = true;
                        }
                    }
                }

                ListView {
                    for link in root.links: HorizontalLayout {
                        spacing: 10px;

                        Text {
                            text: link.id;
                            vertical-alignment: center;
                        }

                        Text {
                            text: link.name;
                            vertical-alignment: center;
                        }

                        Text {
                            text: link.url;
                            vertical-alignment: center;
                        }

                        Button {
                            text: "编辑";
                            clicked => {
                                root.edit_id = link.id;
                                root.edit_name = link.name;
                                root.edit_url = link.url;
                                root.show_edit_dialog = true;
                            }
                        }

                        Button {
                            text: "删除";
                            clicked => {
                                root.edit_id = link.id;
                                root.edit_name = link.name;
                                root.show_delete_dialog = true;
                            }
                        }
                    }
                }
            }

            if (root.message_text != "") : Rectangle {
                background: root.message_type == "success" ? #4caf50 : #f44336;
                width: 100%;
                height: 40px;

                Text {
                    text: root.message_text;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => {
                        root.message_text = "";
                    }
                }
            }
        }

        if (root.show_add_dialog) : Rectangle {
            background: rgba(0, 0, 0, 0.5);
            width: parent.width;
            height: parent.height;

            Rectangle {
                width: 400px;
                height: 250px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;

                    Text {
                        text: "添加新节目";
                        font-size: 20px;
                    }

                    LineEdit {
                        text <=> root.edit_name;
                        placeholder-text: "节目名称";
                    }

                    LineEdit {
                        text <=> root.edit_url;
                        placeholder-text: "直播链接";
                    }

                    HorizontalBox {
                        StandardButton {
                            kind: cancel;
                            clicked => {
                                root.show_add_dialog = false;
                            }
                        }

                        Button {
                            text: "添加";
                            clicked => {
                                root.add_link();
                            }
                        }
                    }
                }
            }
        }

        if (root.show_edit_dialog) : Rectangle {
            background: rgba(0, 0, 0, 0.5);
            width: parent.width;
            height: parent.height;

            Rectangle {
                width: 400px;
                height: 250px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;

                    Text {
                        text: "编辑节目";
                        font-size: 20px;
                    }

                    LineEdit {
                        text <=> root.edit_name;
                        placeholder-text: "节目名称";
                    }

                    LineEdit {
                        text <=> root.edit_url;
                        placeholder-text: "直播链接";
                    }

                    HorizontalBox {
                        StandardButton {
                            kind: cancel;
                            clicked => {
                                root.show_edit_dialog = false;
                            }
                        }

                        Button {
                            text: "更新";
                            clicked => {
                                root.update_link(root.edit_id, root.edit_name, root.edit_url);
                            }
                        }
                    }
                }
            }
        }

        if (root.show_delete_dialog) : Rectangle {
            background: rgba(0, 0, 0, 0.5);
            width: parent.width;
            height: parent.height;

            Rectangle {
                width: 400px;
                height: 180px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;

                    Text {
                        text: "确认删除";
                        font-size: 20px;
                    }

                    Text {
                        text: "确定要删除节目 " + root.edit_name + " 吗？此操作不可恢复。";
                    }

                    HorizontalBox {
                        StandardButton {
                            kind: cancel;
                            clicked => {
                                root.show_delete_dialog = false;
                            }
                        }

                        StandardButton {
                            kind: yes;
                            clicked => {
                                root.delete_link(root.edit_id);
                            }
                        }
                    }
                }
            }
        }
    }
}
