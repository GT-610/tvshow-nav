import { Button, LineEdit, ListView, HorizontalBox, VerticalBox } from "std-widgets.slint";

struct LinkItem {
    id: int,
    name: string,
    url: string,
}

export component MainWindow inherits Window {
    in-out property <bool> is_manage_page: false;
    in-out property <[LinkItem]> links: [];
    in-out property <string> edit_name: "";
    in-out property <string> edit_url: "";
    in-out property <int> edit_id: 0;
    in-out property <bool> show_add_dialog: false;
    in-out property <bool> show_edit_dialog: false;
    in-out property <bool> show_delete_dialog: false;
    in-out property <string> message_text: "";
    in-out property <string> message_type: "success";

    width: 900px;
    height: 700px;
    title: "电视直播导航";

    callback add_link();
    callback update_link(int, string, string);
    callback delete_link(int);
    callback show_message(string, string);
    callback open_link(string);
    callback edit_link(int);
    callback remove_link(int);

    public function navigate-to-manage() {
        self.is_manage_page = true;
    }

    public function navigate-to-home() {
        self.is_manage_page = false;
    }

    Rectangle {
        width: 100%;
        height: 100%;

        VerticalBox {
            padding: 20px;
            spacing: 15px;

            HorizontalBox {
                Text {
                    text: "电视直播导航";
                    font-size: 24px;
                }

                HorizontalLayout {
                    horizontal-stretch: 1;
                }

                if (!root.is_manage_page) : Button {
                    text: "管理节目";
                    clicked => {
                        root.navigate-to-manage();
                    }
                }

                if (root.is_manage_page) : Button {
                    text: "返回首页";
                    clicked => {
                        root.navigate-to-home();
                    }
                }
            }

            if (!root.is_manage_page) : VerticalBox {
                spacing: 10px;

                Text {
                    text: "轻松跳转到您喜爱的电视台直播";
                    font-size: 14px;
                    color: #666;
                }

                ListView {
                    width: 100%;
                    height: 100%;

                    for link in root.links: HorizontalLayout {
                        spacing: 10px;
                        padding: 8px;

                        Text {
                            text: link.id;
                            width: 50px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: link.name;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: link.url;
                            color: #666;
                            horizontal-alignment: center;
                        }

                        HorizontalLayout {
                            spacing: 5px;
                            width: 120px;

                            Button {
                                text: "编辑";
                                clicked => {
                                    root.edit_link(link.id);
                                }
                            }

                            Button {
                                text: "删除";
                                clicked => {
                                    root.remove_link(link.id);
                                }
                            }
                        }
                    }
                }
            }

            if (root.is_manage_page) : VerticalBox {
                spacing: 10px;

                HorizontalBox {
                    Text {
                        text: "节目列表";
                        font-size: 18px;
                    }

                    HorizontalLayout {
                        horizontal-stretch: 1;
                    }

                    Button {
                        text: "添加节目";
                        clicked => {
                            root.edit_name = "";
                            root.edit_url = "";
                            root.edit_id = 0;
                            root.show_add_dialog = true;
                        }
                    }
                }

                VerticalBox {
                    width: 100%;
                    height: 100%;

                    HorizontalLayout {
                        padding: 8px;
                        spacing: 5px;

                        Text {
                            text: "编号";
                            width: 50px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "节目名称";
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "直播链接";
                            horizontal-alignment: center;
                        }

                        HorizontalLayout {
                            width: 120px;

                            Text {
                                text: "操作";
                                horizontal-alignment: center;
                            }
                        }
                    }

                    ListView {
                        width: 100%;
                        height: 100%;

                        for link in root.links: HorizontalLayout {
                            padding: 8px;
                            spacing: 5px;

                            Text {
                                text: link.id;
                                width: 50px;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: link.name;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: link.url;
                                color: #666;
                                horizontal-alignment: center;
                            }

                            HorizontalLayout {
                                spacing: 5px;
                                width: 120px;

                                Button {
                                    text: "编辑";
                                    clicked => {
                                        root.edit_link(link.id);
                                    }
                                }

                                Button {
                                    text: "删除";
                                    clicked => {
                                        root.remove_link(link.id);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if (root.message_text != "") : Rectangle {
                background: root.message_type == "success" ? #4caf50 : #f44336;
                width: 100%;
                height: 40px;
                border-radius: 8px;

                Text {
                    text: root.message_text;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => {
                        root.message_text = "";
                    }
                }
            }
        }

        if (root.show_add_dialog) : Rectangle {
            background: rgba(0, 0, 0, 0.5);
            width: parent.width;
            height: parent.height;

            Rectangle {
                width: 400px;
                height: 280px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 16px;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;

                    Text {
                        text: "添加新节目";
                        font-size: 20px;
                        font-weight: 600;
                    }

                    LineEdit {
                        text <=> root.edit_name;
                        placeholder-text: "请输入节目名称";
                        height: 40px;
                    }

                    LineEdit {
                        text <=> root.edit_url;
                        placeholder-text: "请输入直播链接";
                        height: 40px;
                    }

                    HorizontalBox {
                        spacing: 10px;

                        Button {
                            text: "添加";
                            clicked => {
                                root.add_link();
                            }
                        }

                        Button {
                            text: "取消";
                            clicked => {
                                root.show_add_dialog = false;
                            }
                        }
                    }
                }
            }
        }

        if (root.show_edit_dialog) : Rectangle {
            background: rgba(0, 0, 0, 0.5);
            width: parent.width;
            height: parent.height;

            Rectangle {
                width: 400px;
                height: 280px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 16px;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;

                    Text {
                        text: "编辑节目";
                        font-size: 20px;
                        font-weight: 600;
                    }

                    LineEdit {
                        text <=> root.edit_name;
                        placeholder-text: "请输入节目名称";
                        height: 40px;
                    }

                    LineEdit {
                        text <=> root.edit_url;
                        placeholder-text: "请输入直播链接";
                        height: 40px;
                    }

                    HorizontalBox {
                        spacing: 10px;

                        Button {
                            text: "更新";
                            clicked => {
                                root.update_link(root.edit_id, root.edit_name, root.edit_url);
                            }
                        }

                        Button {
                            text: "取消";
                            clicked => {
                                root.show_edit_dialog = false;
                            }
                        }
                    }
                }
            }
        }

        if (root.show_delete_dialog) : Rectangle {
            background: rgba(0, 0, 0, 0.5);
            width: parent.width;
            height: parent.height;

            Rectangle {
                width: 400px;
                height: 200px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 16px;

                VerticalBox {
                    padding: 20px;
                    spacing: 15px;

                    Text {
                        text: "确认删除";
                        font-size: 20px;
                        font-weight: 600;
                    }

                    Text {
                        text: "确定要删除节目 " + root.edit_name + " 吗？此操作不可恢复。";
                        wrap: word-wrap;
                    }

                    HorizontalBox {
                        spacing: 10px;

                        Button {
                            text: "确定";
                            clicked => {
                                root.delete_link(root.edit_id);
                            }
                        }

                        Button {
                            text: "取消";
                            clicked => {
                                root.show_delete_dialog = false;
                            }
                        }
                    }
                }
            }
        }
    }
}
